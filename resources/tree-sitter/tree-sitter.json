{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mollie",
      "camelcase": "Mollie",
      "title": "Mollie",
      "scope": "source.mollie",
      "file-types": [
        "mollie",
        "mol"
      ],
      "injection-regex": "^mollie$",
      "class-name": "TreeSitterMollie"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Mollie grammar for tree-sitter",
    "authors": [
      {
        "name": "AivingDev",
        "email": "bellyinkognito05@gmail.com",
        "url": "https://github.com/Aiving"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mollie"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}